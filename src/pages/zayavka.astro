---
// Анкета на обследование (4 шага + финал).
// Перенесено ДОСЛОВНО из «страница заявки.html».
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import finalImg from '../assets/img/img-quiz-final-1f68511d.jpg';
---

<Base title="INFO CLINIC · Анкета на обследование">
  <div class="wrap">

    <!-- top -->
    <div class="top" id="topbar">
      <button class="back" id="back" aria-label="Назад">
        <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"></path></svg>
      </button>
      <div class="prog">
        <div class="prog-top">
          <span class="brand">
            <svg viewBox="0 0 40 40">
              <circle cx="20" cy="20" r="17" stroke="#C9A24B" stroke-width="1.3" fill="none" opacity=".5"></circle>
              <path d="M7 20h6l3-8 5 16 3-8h9" stroke="#3FDD9A" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            INFO CLINIC
          </span>
          <span class="stepno" id="stepno">Шаг 1 из 4</span>
        </div>
        <div class="bar"><div class="bar-fill" id="barfill" style="width: 10%;"></div></div>
      </div>
    </div>

    <div class="stage" id="stage">

      <!-- STEP 1 -->
      <div class="step active" data-step="1">
        <span class="eyebrow">Анкета на обследование</span>
        <h1>Перед обследованием нужно оформить карточку пациента</h1>
        <p class="q sub">Ответьте на несколько коротких вопросов. Это поможет быстрее понять вашу ситуацию и подготовиться к диагностике.</p>
        <p class="q">В какой нише вы работаете или планируете запускать онлайн-продукт?</p>
        <div class="opts" data-q="niche">
          <button class="opt" data-val="Психология"><span>Психология</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Эзотерика"><span>Эзотерика</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Здоровье"><span>Здоровье</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Beauty"><span>Beauty</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Обучение профессиям"><span>Обучение профессиям</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Заработок"><span>Заработок</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Услуги"><span>Услуги</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="__other" data-other="1"><span>Другая ниша</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
        </div>
        <div class="custom" id="nicheCustom">
          <input class="field" id="nicheInput" type="text" placeholder="Напишите вашу нишу" autocomplete="off" />
          <button class="btn mini" id="nicheConfirm">Продолжить <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></button>
        </div>
      </div>

      <!-- STEP 2 -->
      <div class="step" data-step="2">
        <span class="eyebrow">Цель</span>
        <p class="q">На какой доход вы хотите выйти через 3 месяца?</p>
        <div class="opts one" data-q="goal">
          <button class="opt" data-val="До 3 000$"><span>До 3 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="3 000$ - 6 000$"><span>3 000$ - 6 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="6 000$ - 10 000$"><span>6 000$ - 10 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="10 000$++"><span>10 000$+</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
        </div>
      </div>

      <!-- STEP 3 -->
      <div class="step" data-step="3">
        <span class="eyebrow">Текущая точка</span>
        <p class="q">Какой ваш текущий ежемесячный доход со всех проектов?</p>
        <div class="opts" data-q="income">
          <button class="opt" data-val="До 800$"><span>До 800$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="800$ - 1 500$"><span>800$ - 1 500$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="1 500$ - 3 000$"><span>1 500$ - 3 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="3 000$ - 5 000$"><span>3 000$ - 5 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="5 000$ - 10 000$"><span>5 000$ - 10 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="10 000$++"><span>10 000$+</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
        </div>
      </div>

      <!-- STEP 4 -->
      <div class="step" data-step="4">
        <span class="eyebrow">Последний шаг</span>
        <h1>Последний шаг перед обследованием</h1>
        <div class="fields">
          <div>
            <label class="flabel" for="ig">Instagram</label>
            <input class="field" id="ig" type="text" placeholder="@username или ссылка" autocomplete="off" />
          </div>
          <div>
            <label class="flabel" for="tg">Telegram</label>
            <input class="field" id="tg" type="text" placeholder="@username или ссылка" autocomplete="off" />
          </div>
        </div>
        <p class="note">Достаточно указать хотя бы один контакт.</p>
        <button class="btn" id="submit" disabled>Отправить заявку <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></button>
      </div>

    </div>

    <!-- FINAL -->
    <div class="final" id="final">
      <div class="final-img">
        <Image src={finalImg} alt="Карточка пациента" />
      </div>
      <div class="final-text">
        <p>Ваша заявка на обследование проекта принята. Сейчас она находится на рассмотрении и уже передана в приёмную INFO CLINIC. Нам потребуется немного времени, чтобы ознакомиться с вашим проектом.</p>
        <div class="nextstep">Обязательный следующий шаг</div>
        <p class="rec">Перейдите в Telegram. Там находятся дополнительные материалы по методике обследования, кейсы и вся дальнейшая информация по записи.</p>
        <a class="btn ghost" href="https://t.me/your_bot_link" target="_blank" rel="noopener">Перейти в Telegram <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>
      </div>
    </div>

  </div>
</Base>

<style>
  .wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
    padding: 22px 20px 48px;
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 120px);
    justify-content: center;
  }

  /* top */
  .top {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 26px;
    margin-top: 20px;
  }
  .back {
    width: 38px;
    height: 38px;
    flex: none;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--bone);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.25s var(--ease);
    opacity: 0;
    pointer-events: none;
  }
  .back.show {
    opacity: 1;
    pointer-events: auto;
  }
  .back:hover {
    border-color: var(--vital-line);
  }
  .back svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
  }
  .prog {
    flex: 1;
  }
  .prog-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 9px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .brand svg {
    width: 18px;
    height: 18px;
  }
  .stepno {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--mute);
  }
  .bar {
    height: 5px;
    border-radius: 100px;
    background: var(--surface-2);
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    width: 10%;
    border-radius: 100px;
    background: linear-gradient(90deg, var(--vital), #7af0c0);
    box-shadow: 0 0 14px var(--vital-line);
    transition: width 0.5s cubic-bezier(.2, .7, .3, 1);
  }

  /* steps */
  .stage {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .step {
    display: none;
  }
  .step.active {
    display: block;
    animation: fade 0.45s cubic-bezier(.2, .7, .3, 1);
  }
  @keyframes fade {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: none; }
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--vital);
    margin-bottom: 16px;
  }
  .eyebrow::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--vital);
    box-shadow: 0 0 10px var(--vital);
  }
  h1 {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(21px, 4.4vw, 28px);
    line-height: 1.2;
    letter-spacing: -.01em;
    margin-bottom: 10px;
  }
  .q {
    font-size: clamp(16px, 2.4vw, 19px);
    line-height: 1.4;
    color: var(--bone);
    font-weight: 400;
    margin-bottom: 24px;
  }
  .q.sub {
    color: var(--mute);
    font-weight: 300;
    font-size: 15px;
    margin-top: -2px;
    margin-bottom: 26px;
  }

  /* option cards */
  .opts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 11px;
  }
  .opts.one {
    grid-template-columns: 1fr;
  }
  @media (max-width: 430px) {
    .opts { grid-template-columns: 1fr; }
  }
  .opt {
    position: relative;
    text-align: left;
    border: 1px solid var(--line);
    background: linear-gradient(160deg, var(--surface-2), var(--surface));
    border-radius: 14px;
    padding: 18px 18px;
    font-family: var(--font-sans);
    font-size: 15.5px;
    font-weight: 500;
    color: var(--bone);
    cursor: pointer;
    transition: all 0.25s var(--ease);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .opt:hover {
    border-color: var(--vital-line);
    transform: translateY(-2px);
  }
  .opt .tick {
    width: 22px;
    height: 22px;
    flex: none;
    border-radius: 50%;
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s var(--ease);
  }
  .opt .tick svg {
    width: 12px;
    height: 12px;
    fill: none;
    stroke: var(--vital);
    stroke-width: 2.6;
    opacity: 0;
    transition: opacity 0.2s var(--ease);
  }
  .opt.sel {
    border-color: var(--vital);
    background: var(--vital-soft);
  }
  .opt.sel .tick {
    background: var(--vital);
    border-color: var(--vital);
  }
  .opt.sel .tick svg {
    stroke: #04140C;
    opacity: 1;
  }

  /* custom niche input */
  .custom {
    margin-top: 12px;
    display: none;
  }
  .custom.show {
    display: block;
    animation: fade 0.35s var(--ease);
  }
  .field {
    width: 100%;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 16px 16px;
    color: var(--bone);
    font-family: var(--font-sans);
    font-size: 16px;
    outline: none;
    transition: border-color 0.25s var(--ease);
  }
  .field::placeholder {
    color: var(--mute-2);
  }
  .field:focus {
    border-color: var(--vital-line);
  }

  /* contact step */
  .fields {
    display: flex;
    flex-direction: column;
    gap: 13px;
    margin-bottom: 8px;
  }
  .flabel {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--mute-2);
    margin-bottom: 8px;
    display: block;
  }
  .note {
    font-size: 12.5px;
    color: var(--mute-2);
    margin-top: 14px;
    line-height: 1.5;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    background: var(--vital);
    color: #04140C;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 16px;
    padding: 18px 28px;
    border-radius: 100px;
    border: none;
    cursor: pointer;
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease), opacity 0.25s var(--ease);
    margin-top: 22px;
  }
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px -12px var(--vital-line);
  }
  .btn:disabled {
    opacity: .4;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }
  .btn svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: #04140C;
    stroke-width: 2.2;
  }
  .btn.mini {
    width: auto;
    padding: 13px 24px;
    font-size: 14px;
    margin-top: 14px;
  }
  .btn.ghost {
    background: transparent;
    color: var(--bone);
    border: 1px solid var(--vital-line);
  }
  .btn.ghost svg {
    stroke: var(--vital);
  }

  /* final */
  .final {
    display: none;
  }
  .final.active {
    display: grid;
    grid-template-columns: 1fr;
    gap: 26px;
    align-items: center;
    flex: 1;
    animation: fade 0.5s var(--ease);
  }
  @media (min-width: 760px) {
    .final.active {
      grid-template-columns: 1.05fr 1fr;
      gap: 44px;
    }
  }
  .final-img :global(img) {
    width: 100%;
    display: block;
    height: auto;
    border-radius: 16px;
    border: 1px solid var(--line);
    box-shadow: 0 30px 70px -36px rgba(0,0,0,.85);
  }
  .final-img .doc2 {
    max-width: 300px;
    margin-left: auto;
    margin-right: auto;
  }
  .final-text {
    text-align: left;
  }
  .final-text p {
    color: var(--mute);
    font-size: 15.5px;
    line-height: 1.6;
    margin-bottom: 14px;
  }
  .nextstep {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--vital);
    margin: 10px 0 12px;
  }
  .nextstep::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--vital);
    box-shadow: 0 0 10px var(--vital);
  }
  @media (max-width: 759px) {
    .final-img { order: 2; }
    .final-text { order: 1; }
  }
  .wrap.wide {
    max-width: 920px;
  }
  .seal {
    width: 84px;
    height: 84px;
    border-radius: 50%;
    background: var(--vital-soft);
    border: 1px solid var(--vital-line);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 26px;
    animation: pop-animation .5s cubic-bezier(.2,1.4,.5,1);
  }
  .seal svg {
    width: 38px;
    height: 38px;
    fill: none;
    stroke: var(--vital);
    stroke-width: 2.4;
  }
  @keyframes pop-animation {
    from { transform: scale(.5); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
  .final h1 {
    margin-bottom: 18px;
  }
  .final p {
    color: var(--mute);
    font-size: 15.5px;
    line-height: 1.6;
    max-width: 42ch;
    margin-bottom: 14px;
  }
  .final .rec {
    color: var(--bone);
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation: none !important; transition: none !important; }
  }
</style>

<script>
  (function(){
    const TOTAL = 4;
    let cur = 1;
    const answers = { niche: null, goal: null, income: null, ig: '', tg: '' };

    const stepno = document.getElementById('stepno');
    const barfill = document.getElementById('barfill');
    const back = document.getElementById('back');
    const steps = document.querySelectorAll('.step');
    const stage = document.getElementById('stage');
    const finalEl = document.getElementById('final');
    const topbar = document.getElementById('topbar');

    function progressPct(step) {
      return Math.round(10 + (step - 1) / (TOTAL) * 90);
    }

    function render() {
      steps.forEach(function(s) {
        const stepEl = s as HTMLElement;
        stepEl.classList.toggle('active', parseInt(stepEl.dataset.step || '0', 10) === cur);
      });
      if (stepno) stepno.textContent = 'Шаг ' + cur + ' из ' + TOTAL;
      if (barfill) barfill.style.width = progressPct(cur) + '%';
      if (back) back.classList.toggle('show', cur > 1);
    }

    function go(step: number) {
      cur = step;
      render();
    }

    // option selection
    document.querySelectorAll('.opts').forEach(function(group) {
      group.addEventListener('click', function(e) {
        const target = e.target as HTMLElement;
        const btn = target.closest('.opt') as HTMLElement | null;
        if (!btn) return;

        const groupEl = group as HTMLElement;
        const q = groupEl.dataset.q as keyof typeof answers;

        // visual select
        groupEl.querySelectorAll('.opt').forEach(function(o) {
          o.classList.remove('sel');
        });
        btn.classList.add('sel');

        const custom = document.getElementById('nicheCustom');
        if (btn.dataset.other) {
          if (custom) custom.classList.add('show');
          const ni = document.getElementById('nicheInput') as HTMLInputElement | null;
          if (ni) ni.focus();
          return; // wait for confirm
        }

        if (custom) custom.classList.remove('show');
        const val = btn.dataset.val;
        if (val && q) {
          answers[q] = val;
        }
        setTimeout(function() {
          next();
        }, 260);
      });
    });

    // custom niche confirm
    const nc = document.getElementById('nicheConfirm');
    if (nc) {
      nc.addEventListener('click', function() {
        const nicheInput = document.getElementById('nicheInput') as HTMLInputElement | null;
        if (!nicheInput) return;
        const v = nicheInput.value.trim();
        if (!v) {
          nicheInput.focus();
          return;
        }
        answers.niche = v;
        next();
      });

      const nicheInput = document.getElementById('nicheInput');
      if (nicheInput) {
        nicheInput.addEventListener('keydown', function(e) {
          const keyEvent = e as KeyboardEvent;
          if (keyEvent.key === 'Enter') {
            keyEvent.preventDefault();
            (nc as HTMLElement).click();
          }
        });
      }
    }

    function next() {
      if (cur < TOTAL) {
        go(cur + 1);
      }
    }

    if (back) {
      back.addEventListener('click', function() {
        if (cur > 1) go(cur - 1);
      });
    }

    // contact step validation
    const ig = document.getElementById('ig') as HTMLInputElement | null;
    const tg = document.getElementById('tg') as HTMLInputElement | null;
    const submit = document.getElementById('submit') as HTMLButtonElement | null;

    function checkContact() {
      if (!ig || !tg || !submit) return;
      const ok = (ig.value.trim().length > 1) || (tg.value.trim().length > 1);
      submit.disabled = !ok;
    }

    if (ig) ig.addEventListener('input', checkContact);
    if (tg) tg.addEventListener('input', checkContact);

    if (submit) {
      submit.addEventListener('click', function() {
        if (!ig || !tg) return;
        answers.ig = ig.value.trim();
        answers.tg = tg.value.trim();

        // TODO: В Фазе 2 подключить реальный приёмник заявок (TG bot / webhook / CRM)
        console.log('Отправка анкеты:', answers);

        if (topbar) topbar.style.display = 'none';
        const wrapEl = document.querySelector('.wrap');
        if (wrapEl) wrapEl.classList.add('wide');
        if (stage) stage.style.display = 'none';
        if (finalEl) finalEl.classList.add('active');
        if (barfill) barfill.style.width = '100%';
      });
    }

    render();
  })();
