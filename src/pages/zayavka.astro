---
// Анкета на обследование (4 шага + финал).
// Перенесено ДОСЛОВНО из «страница заявки.html».
import Base from '../layouts/Base.astro';
---

<Base title="INFO CLINIC · Анкета на обследование">
  <div class="wrap">

    <!-- top -->
    <div class="top" id="topbar">
      <button class="back" id="back" aria-label="Назад">
        <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"></path></svg>
      </button>
      <div class="prog">
        <div class="prog-top">
          <span class="brand">
            <svg viewBox="0 0 40 40">
              <circle cx="20" cy="20" r="17" stroke="#C9A24B" stroke-width="1.3" fill="none" opacity=".5"></circle>
              <path d="M7 20h6l3-8 5 16 3-8h9" stroke="#3FDD9A" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            INFO CLINIC
          </span>
          <span class="stepno" id="stepno">Шаг 1 из 4</span>
        </div>
        <div class="bar"><div class="bar-fill" id="barfill" style="width: 10%;"></div></div>
      </div>
    </div>

    <div class="stage" id="stage">

      <!-- STEP 1 -->
      <div class="step active" data-step="1">
        <span class="eyebrow">Анкета на обследование</span>
        <h1>Перед обследованием нужно оформить карточку пациента</h1>
        <p class="q sub">Ответьте на несколько коротких вопросов. Это поможет быстрее понять вашу ситуацию и подготовиться к диагностике.</p>
        <p class="q">В какой нише вы работаете или планируете запускать онлайн-продукт?</p>
        <div class="opts" data-q="niche">
          <button class="opt" data-val="Психология"><span>Психология</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Эзотерика"><span>Эзотерика</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Здоровье"><span>Здоровье</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Beauty"><span>Beauty</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Обучение профессиям"><span>Обучение профессиям</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Заработок"><span>Заработок</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Услуги"><span>Услуги</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="__other" data-other="1"><span>Другая ниша</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
        </div>
        <div class="custom" id="nicheCustom">
          <input class="field" id="nicheInput" type="text" placeholder="Напишите вашу нишу" autocomplete="off" />
          <button class="btn mini" id="nicheConfirm">Продолжить <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></button>
        </div>
      </div>

      <!-- STEP 2 -->
      <div class="step" data-step="2">
        <span class="eyebrow">Цель</span>
        <p class="q">На какой доход вы хотите выйти через 3 месяца?</p>
        <div class="opts one" data-q="goal">
          <button class="opt" data-val="До 3 000$"><span>До 3 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="3 000$ - 6 000$"><span>3 000$ - 6 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="6 000$ - 10 000$"><span>6 000$ - 10 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="10 000$++"><span>10 000$+</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
        </div>
      </div>

      <!-- STEP 3 -->
      <div class="step" data-step="3">
        <span class="eyebrow">Текущая точка</span>
        <p class="q">Какой ваш текущий ежемесячный доход со всех проектов?</p>
        <div class="opts" data-q="income">
          <button class="opt" data-val="До 800$"><span>До 800$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="800$ - 1 500$"><span>800$ - 1 500$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="1 500$ - 3 000$"><span>1 500$ - 3 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="3 000$ - 5 000$"><span>3 000$ - 5 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="5 000$ - 10 000$"><span>5 000$ - 10 000$</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="10 000$++"><span>10 000$+</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
        </div>
      </div>

      <!-- STEP 4 -->
      <div class="step" data-step="4">
        <span class="eyebrow">Готовность</span>
        <p class="q sub">Как показывает практика, чтобы выйти на доход $10 000+ в месяц нужно инвестировать своё время, силы и деньги в проект</p>
        <p class="q">Скажите, пожалуйста, насколько вы сейчас готовы к этому?</p>
        <div class="opts one" data-q="readiness">
          <button class="opt" data-val="Да, готов(а) инвестировать в свой проект и выйти на новый уровень"><span>Да, готов(а) инвестировать в свой проект и выйти на новый уровень</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
          <button class="opt" data-val="Пока не готов(а) инвестировать в развитие проекта"><span>Пока не готов(а) инвестировать в развитие проекта</span><span class="tick"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg></span></button>
        </div>
      </div>

      <!-- STEP 5 -->
      <div class="step" data-step="5">
        <span class="eyebrow">Последний шаг</span>
        <h1>Последний шаг перед обследованием</h1>
        <div class="fields">
          <div>
            <label class="flabel" for="ig">Instagram</label>
            <input class="field" id="ig" type="text" placeholder="@username или ссылка" autocomplete="off" />
          </div>
          <div>
            <label class="flabel" for="tg">Telegram</label>
            <input class="field" id="tg" type="text" placeholder="@username или ссылка" autocomplete="off" />
          </div>
        </div>
        <p class="note">Достаточно указать хотя бы один контакт.</p>
        <button class="btn" id="submit" disabled>Отправить заявку <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></button>
      </div>

    </div>

    <!-- FINAL -->
    <div class="final" id="final">
      <div class="final-img">
        <div class="pcard">
          <div class="pcard-head">
            <span class="pcard-brand">
              <svg viewBox="0 0 40 40">
                <circle cx="20" cy="20" r="17" stroke="#1f5e44" stroke-width="1.6" fill="none" opacity=".6"></circle>
                <path d="M7 20h6l3-8 5 16 3-8h9" stroke="#1f7a55" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
              INFO CLINIC
            </span>
            <span class="pcard-id" id="pcId">№ 000000</span>
          </div>
          <div class="pcard-title">Карта пациента</div>
          <div class="pcard-rows">
            <div class="pcard-row" id="rowNiche"><span class="k">Ниша</span><span class="v" id="pcNiche">—</span></div>
            <div class="pcard-row" id="rowGoal"><span class="k">Цель · 3 мес</span><span class="v" id="pcGoal">—</span></div>
            <div class="pcard-row" id="rowIncome"><span class="k">Текущий доход</span><span class="v" id="pcIncome">—</span></div>
            <div class="pcard-row" id="rowIg"><span class="k">Instagram</span><span class="v" id="pcIg">—</span></div>
            <div class="pcard-row" id="rowTg"><span class="k">Telegram</span><span class="v" id="pcTg">—</span></div>
          </div>
          <div class="pcard-foot">
            <div class="pcard-sign">
              <span class="pcard-signmark">INFO CLINIC</span>
              <span class="pcard-signcap">приёмная клиники</span>
            </div>
            <div class="pcard-stamp">
              <span class="stamp-top">принято</span>
              <span class="stamp-mid">в обработку</span>
            </div>
          </div>
        </div>
      </div>
      <div class="final-text">
        <p>Ваша заявка на обследование проекта принята. Сейчас она находится на рассмотрении и уже передана в приёмную INFO CLINIC. Нам потребуется немного времени, чтобы ознакомиться с вашим проектом.</p>
        <div class="nextstep">Обязательный следующий шаг</div>
        <p class="rec">Перейдите в Telegram. Там находятся дополнительные материалы по методике обследования, кейсы и вся дальнейшая информация по записи.</p>
        <a class="btn lg tg-cta" id="tgBtn" href="https://t.me/your_bot_link" target="_blank" rel="noopener"><span class="tg-label">Перейти в Telegram</span> <svg viewBox="0 0 24 24"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path></svg></a>
        <p class="redir">Автоматический переход в Telegram через <span id="redirCount">10</span> сек…</p>
      </div>
    </div>

  </div>
</Base>

<style>
  .wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
    padding: 22px 20px 48px;
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 120px);
    justify-content: center;
  }

  /* top */
  .top {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 26px;
    margin-top: 20px;
  }
  .back {
    width: 38px;
    height: 38px;
    flex: none;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--bone);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.25s var(--ease);
    opacity: 0;
    pointer-events: none;
  }
  .back.show {
    opacity: 1;
    pointer-events: auto;
  }
  .back:hover {
    border-color: var(--vital-line);
  }
  .back svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
  }
  .prog {
    flex: 1;
  }
  .prog-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 9px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .brand svg {
    width: 18px;
    height: 18px;
  }
  .stepno {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--bone);
  }
  .bar {
    height: 5px;
    border-radius: 100px;
    background: var(--surface-2);
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    width: 10%;
    border-radius: 100px;
    background: linear-gradient(90deg, var(--vital), #7af0c0);
    box-shadow: 0 0 14px var(--vital-line);
    transition: width 0.5s cubic-bezier(.2, .7, .3, 1);
  }

  /* steps */
  .stage {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .step {
    display: none;
  }
  .step.active {
    display: block;
    animation: fade 0.45s cubic-bezier(.2, .7, .3, 1);
  }
  @keyframes fade {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: none; }
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--vital);
    margin-bottom: 16px;
  }
  .eyebrow::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--vital);
    box-shadow: 0 0 10px var(--vital);
  }
  h1 {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(21px, 4.4vw, 28px);
    line-height: 1.2;
    letter-spacing: -.01em;
    margin-bottom: 10px;
  }
  .q {
    font-size: clamp(16px, 2.4vw, 19px);
    line-height: 1.4;
    color: var(--bone);
    font-weight: 400;
    margin-bottom: 24px;
  }
  .q.sub {
    color: var(--bone);
    font-weight: 400;
    font-size: 15px;
    margin-top: -2px;
    margin-bottom: 26px;
  }

  /* option cards */
  .opts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 11px;
  }
  .opts.one {
    grid-template-columns: 1fr;
  }
  @media (max-width: 430px) {
    .opts { grid-template-columns: 1fr; }
  }
  .opt {
    position: relative;
    text-align: left;
    border: 1px solid var(--line);
    background: var(--card);
    border-radius: 14px;
    padding: 18px 18px;
    font-family: var(--font-sans);
    font-size: 15.5px;
    font-weight: 500;
    color: var(--bone);
    cursor: pointer;
    transition: all 0.25s var(--ease);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .opt:hover {
    border-color: var(--vital-line);
    transform: translateY(-2px);
  }
  .opt .tick {
    width: 22px;
    height: 22px;
    flex: none;
    border-radius: 50%;
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s var(--ease);
  }
  .opt .tick svg {
    width: 12px;
    height: 12px;
    fill: none;
    stroke: var(--vital);
    stroke-width: 2.6;
    opacity: 0;
    transition: opacity 0.2s var(--ease);
  }
  .opt.sel {
    border-color: var(--vital);
    background-color: var(--card);
    background-image: linear-gradient(var(--vital-soft), var(--vital-soft));
  }
  .opt.sel .tick {
    background: var(--vital);
    border-color: var(--vital);
  }
  .opt.sel .tick svg {
    stroke: #04140C;
    opacity: 1;
  }

  /* custom niche input */
  .custom {
    margin-top: 12px;
    display: none;
  }
  .custom.show {
    display: block;
    animation: fade 0.35s var(--ease);
  }
  .field {
    width: 100%;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 16px 16px;
    color: var(--bone);
    font-family: var(--font-sans);
    font-size: 16px;
    outline: none;
    transition: border-color 0.25s var(--ease);
  }
  .field::placeholder {
    color: var(--mute);
  }
  .field:focus {
    border-color: var(--vital-line);
  }

  /* contact step */
  .fields {
    display: flex;
    flex-direction: column;
    gap: 13px;
    margin-bottom: 8px;
  }
  .flabel {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--bone);
    margin-bottom: 8px;
    display: block;
  }
  .note {
    font-size: 12.5px;
    color: var(--bone);
    margin-top: 14px;
    line-height: 1.5;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    background: var(--vital);
    color: #04140C;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 16px;
    padding: 18px 28px;
    border-radius: 100px;
    border: none;
    cursor: pointer;
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease), opacity 0.25s var(--ease);
    margin-top: 22px;
  }
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px -12px var(--vital-line);
  }
  .btn:disabled {
    opacity: .4;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }
  .btn svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: #04140C;
    stroke-width: 2.2;
  }
  .btn.mini {
    width: auto;
    padding: 13px 24px;
    font-size: 14px;
    margin-top: 14px;
  }
  .btn.ghost {
    background: transparent;
    color: var(--bone);
    border: 1px solid var(--vital-line);
  }
  .btn.ghost svg {
    stroke: var(--vital);
  }

  /* final */
  .final {
    display: none;
  }
  .final.active {
    display: grid;
    grid-template-columns: 1fr;
    gap: 26px;
    align-items: center;
    flex: 1;
    animation: fade 0.5s var(--ease);
  }
  @media (min-width: 760px) {
    .final.active {
      grid-template-columns: 1.05fr 1fr;
      gap: 44px;
    }
  }
  .final-img :global(img) {
    width: 100%;
    display: block;
    height: auto;
    border-radius: 16px;
    border: 1px solid var(--line);
    box-shadow: 0 30px 70px -36px rgba(0,0,0,.85);
  }
  .final-img .doc2 {
    max-width: 300px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ---- динамическая карта пациента (бумажный документ) ---- */
  .pcard {
    --ink: #2a2620;
    --ink-soft: #6b6256;
    --rule: rgba(42, 38, 32, .28);
    --green-ink: #1f7a55;
    --red-ink: #a8432e;
    position: relative;
    isolation: isolate;
    background:
      radial-gradient(120% 100% at 0% 0%, rgba(255,255,255,.5), transparent 55%),
      linear-gradient(180deg, #f6eede 0%, #ece0c9 100%);
    border: 1px solid #d8cab0;
    border-radius: 5px;
    padding: 26px 26px 22px 42px;
    color: var(--ink);
    box-shadow:
      0 2px 2px rgba(0,0,0,.16),
      0 28px 64px -30px rgba(0,0,0,.85);
    transform: rotate(-0.7deg);
  }
  /* красное поле слева, как в бланке */
  .pcard::before {
    content: ""; position: absolute; top: 0; bottom: 0; left: 28px; width: 1.5px;
    background: rgba(168, 67, 46, .45); z-index: 0;
  }
  /* лёгкая фактура бумаги */
  .pcard::after {
    content: ""; position: absolute; inset: 0; z-index: 0; pointer-events: none;
    border-radius: 5px;
    background: repeating-linear-gradient(0deg, rgba(42,38,32,.022) 0 1px, transparent 1px 3px);
    mix-blend-mode: multiply; opacity: .6;
  }
  .pcard > * { position: relative; z-index: 1; }

  .pcard-head {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 10px;
    padding-bottom: 12px; border-bottom: 2px solid var(--ink);
  }
  .pcard-brand {
    display: inline-flex; align-items: center; gap: 9px;
    font-family: var(--font-mono); font-size: 12px; font-weight: 700; letter-spacing: .16em;
    text-transform: uppercase; color: var(--ink);
  }
  .pcard-brand svg { width: 22px; height: 22px; }
  .pcard-id {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .06em; color: var(--ink-soft);
  }
  .pcard-title {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: .34em;
    text-transform: uppercase; color: var(--red-ink); font-weight: 700;
    margin: 13px 0 4px;
  }
  .pcard-rows { display: flex; flex-direction: column; }
  .pcard-row {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 16px;
    padding: 11px 0; border-bottom: 1px dotted var(--rule);
  }
  .pcard-row .k {
    flex: none;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em;
    text-transform: uppercase; color: var(--ink-soft);
  }
  .pcard-row .v {
    text-align: right; color: var(--ink);
    font-size: 15px; font-weight: 700; line-height: 1.35;
  }
  .pcard-foot {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 14px;
    margin-top: 18px;
  }
  .pcard-sign { display: flex; flex-direction: column; }
  .pcard-signmark {
    font-family: 'Caveat Variable', 'Caveat', cursive;
    font-size: 28px; line-height: .85; color: var(--green-ink);
    transform: rotate(-5deg); transform-origin: left center;
  }
  .pcard-signcap {
    font-family: var(--font-mono); font-size: 8px; letter-spacing: .14em;
    text-transform: uppercase; color: var(--ink-soft);
    border-top: 1px solid var(--rule); padding-top: 4px; margin-top: 8px;
  }
  .pcard-stamp {
    position: relative; flex: none;
    width: 92px; height: 92px; border-radius: 50%;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    border: 2.5px solid var(--green-ink); color: var(--green-ink);
    box-shadow: inset 0 0 0 4px rgba(31, 122, 85, .16);
    transform: rotate(-13deg); opacity: .82;
  }
  .stamp-top {
    font-family: var(--font-mono); font-size: 14px; font-weight: 800;
    letter-spacing: .1em; text-transform: uppercase;
  }
  .stamp-mid {
    font-family: var(--font-mono); font-size: 7.5px; font-weight: 700;
    letter-spacing: .18em; text-transform: uppercase; margin-top: 2px;
  }
  @media (max-width: 759px) {
    .pcard { transform: none; }
  }

  .final-text {
    text-align: left;
  }
  .final-text p {
    color: var(--bone);
    font-size: 15.5px;
    line-height: 1.6;
    margin-bottom: 14px;
  }
  .redir {
    margin-top: 16px !important;
    font-family: var(--font-mono);
    font-size: 12px !important;
    letter-spacing: .04em;
    color: var(--mute) !important;
  }
  .redir #redirCount { color: var(--vital); font-weight: 700; }

  /* ---- акцентная анимированная CTA в Telegram ---- */
  .tg-cta {
    position: relative;
    overflow: hidden;
    color: #04140c;
    font-weight: 700;
    background: linear-gradient(100deg, #3fdd9a 0%, #2bbd7e 50%, #3fdd9a 100%);
    background-size: 200% 100%;
    box-shadow: 0 10px 30px -8px rgba(63, 221, 154, .55);
    animation: tg-glow 2.6s ease-in-out infinite, tg-bg 6s linear infinite;
  }
  .tg-cta .tg-label, .tg-cta svg { position: relative; z-index: 2; }
  .tg-cta svg { stroke: #04140c; transition: transform .35s var(--ease); }
  .tg-cta:hover svg { transform: translateX(4px) rotate(8deg); }
  /* пробегающий блик */
  .tg-cta::before {
    content: "";
    position: absolute; top: 0; left: -75%; width: 55%; height: 100%; z-index: 1;
    background: linear-gradient(100deg, transparent 0%, rgba(255,255,255,.6) 50%, transparent 100%);
    transform: skewX(-20deg);
    animation: tg-sweep 3.4s ease-in-out infinite;
  }
  .tg-cta:hover {
    transform: translateY(-3px) scale(1.025);
    box-shadow: 0 18px 48px -8px rgba(63, 221, 154, .85);
  }
  @keyframes tg-glow {
    0%, 100% { box-shadow: 0 8px 24px -8px rgba(63, 221, 154, .45); }
    50% { box-shadow: 0 16px 44px -6px rgba(63, 221, 154, .85); }
  }
  @keyframes tg-bg {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  @keyframes tg-sweep {
    0% { left: -75%; }
    55%, 100% { left: 130%; }
  }
  .nextstep {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--vital);
    margin: 10px 0 12px;
  }
  .nextstep::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--vital);
    box-shadow: 0 0 10px var(--vital);
  }
  @media (max-width: 759px) {
    .final-img { order: 2; }
    .final-text { order: 1; }
  }
  .wrap.wide {
    max-width: 920px;
  }
  .seal {
    width: 84px;
    height: 84px;
    border-radius: 50%;
    background: var(--vital-soft);
    border: 1px solid var(--vital-line);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 26px;
    animation: pop-animation .5s cubic-bezier(.2,1.4,.5,1);
  }
  .seal svg {
    width: 38px;
    height: 38px;
    fill: none;
    stroke: var(--vital);
    stroke-width: 2.4;
  }
  @keyframes pop-animation {
    from { transform: scale(.5); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
  .final h1 {
    margin-bottom: 18px;
  }
  .final p {
    color: var(--mute);
    font-size: 15.5px;
    line-height: 1.6;
    max-width: 42ch;
    margin-bottom: 14px;
  }
  .final .rec {
    color: var(--bone);
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation: none !important; transition: none !important; }
  }
</style>

<script>
  (function(){
    const TOTAL = 5;
    let cur = 1;
    const answers = { niche: null, goal: null, income: null, readiness: null, ig: '', tg: '' };

    const stepno = document.getElementById('stepno');
    const barfill = document.getElementById('barfill');
    const back = document.getElementById('back');
    const steps = document.querySelectorAll('.step');
    const stage = document.getElementById('stage');
    const finalEl = document.getElementById('final');
    const topbar = document.getElementById('topbar');

    function progressPct(step) {
      return Math.round(10 + (step - 1) / (TOTAL) * 90);
    }

    function render() {
      steps.forEach(function(s) {
        const stepEl = s as HTMLElement;
        stepEl.classList.toggle('active', parseInt(stepEl.dataset.step || '0', 10) === cur);
      });
      if (stepno) stepno.textContent = 'Шаг ' + cur + ' из ' + TOTAL;
      if (barfill) barfill.style.width = progressPct(cur) + '%';
      if (back) back.classList.add('show');
    }

    function go(step: number) {
      cur = step;
      render();
    }

    // option selection
    document.querySelectorAll('.opts').forEach(function(group) {
      group.addEventListener('click', function(e) {
        const target = e.target as HTMLElement;
        const btn = target.closest('.opt') as HTMLElement | null;
        if (!btn) return;

        const groupEl = group as HTMLElement;
        const q = groupEl.dataset.q as keyof typeof answers;

        // visual select
        groupEl.querySelectorAll('.opt').forEach(function(o) {
          o.classList.remove('sel');
        });
        btn.classList.add('sel');

        const custom = document.getElementById('nicheCustom');
        if (btn.dataset.other) {
          if (custom) custom.classList.add('show');
          const ni = document.getElementById('nicheInput') as HTMLInputElement | null;
          if (ni) ni.focus();
          return; // wait for confirm
        }

        if (custom) custom.classList.remove('show');
        const val = btn.dataset.val;
        if (val && q) {
          answers[q] = val;
        }
        setTimeout(function() {
          next();
        }, 260);
      });
    });

    // custom niche confirm
    const nc = document.getElementById('nicheConfirm');
    if (nc) {
      nc.addEventListener('click', function() {
        const nicheInput = document.getElementById('nicheInput') as HTMLInputElement | null;
        if (!nicheInput) return;
        const v = nicheInput.value.trim();
        if (!v) {
          nicheInput.focus();
          return;
        }
        answers.niche = v;
        next();
      });

      const nicheInput = document.getElementById('nicheInput');
      if (nicheInput) {
        nicheInput.addEventListener('keydown', function(e) {
          const keyEvent = e as KeyboardEvent;
          if (keyEvent.key === 'Enter') {
            keyEvent.preventDefault();
            (nc as HTMLElement).click();
          }
        });
      }
    }

    function next() {
      if (cur < TOTAL) {
        go(cur + 1);
      }
    }

    if (back) {
      back.addEventListener('click', function() {
        if (cur > 1) {
          go(cur - 1);
        } else {
          window.location.href = '/';
        }
      });
    }

    // contact step validation
    const ig = document.getElementById('ig') as HTMLInputElement | null;
    const tg = document.getElementById('tg') as HTMLInputElement | null;
    const submit = document.getElementById('submit') as HTMLButtonElement | null;

    function checkContact() {
      if (!ig || !tg || !submit) return;
      const ok = (ig.value.trim().length > 1) || (tg.value.trim().length > 1);
      submit.disabled = !ok;
    }

    if (ig) ig.addEventListener('input', checkContact);
    if (tg) tg.addEventListener('input', checkContact);

    // заполнение динамической «карты пациента» из ответов
    function fillPatientCard() {
      function setRow(rowId: string, valId: string, value: string) {
        const row = document.getElementById(rowId);
        const v = document.getElementById(valId);
        if (!row || !v) return;
        if (value && value.trim()) {
          v.textContent = value.trim();
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      }
      setRow('rowNiche', 'pcNiche', answers.niche || '');
      setRow('rowGoal', 'pcGoal', answers.goal || '');
      setRow('rowIncome', 'pcIncome', answers.income || '');
      setRow('rowIg', 'pcIg', answers.ig);
      setRow('rowTg', 'pcTg', answers.tg);

      const idEl = document.getElementById('pcId');
      if (idEl) {
        const n = Math.floor(100000 + Math.random() * 900000);
        idEl.textContent = '№ ' + n;
      }
    }

    // авто-переход в Telegram через 10 секунд с обратным отсчётом
    function startTelegramRedirect() {
      const tgBtn = document.getElementById('tgBtn') as HTMLAnchorElement | null;
      const countEl = document.getElementById('redirCount');
      const link = tgBtn ? tgBtn.href : '';
      let left = 10;
      if (countEl) countEl.textContent = String(left);
      const timer = window.setInterval(function() {
        left -= 1;
        if (countEl) countEl.textContent = String(Math.max(left, 0));
        if (left <= 0) {
          window.clearInterval(timer);
          if (link) window.location.href = link;
        }
      }, 1000);
    }

    if (submit) {
      submit.addEventListener('click', function() {
        if (!ig || !tg) return;
        answers.ig = ig.value.trim();
        answers.tg = tg.value.trim();

        // TODO: В Фазе 2 подключить реальный приёмник заявок (TG bot / webhook / CRM)
        console.log('Отправка анкеты:', answers);

        fillPatientCard();

        if (topbar) topbar.style.display = 'none';
        const wrapEl = document.querySelector('.wrap');
        if (wrapEl) wrapEl.classList.add('wide');
        if (stage) stage.style.display = 'none';
        if (finalEl) finalEl.classList.add('active');
        if (barfill) barfill.style.width = '100%';

        startTelegramRedirect();
      });
    }

    render();
  })();
</script>
