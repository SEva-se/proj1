---
// Шапка. Текст дословно из исходника blk1 .topbar:
// логотип «INFO CLINIC», рейтинг «★★★★★ 5.0 · 100+ обследований», кнопка «Записаться».
// Кнопка ведёт на анкету (требование: CTA → форма).
---
<header class="topbar">
  <div class="tb-container">
    <a href="/" class="logo">
      <span class="logo-mark">
        <svg viewBox="0 0 24 24"><path d="M3 12h4l2-5 3 11 2-7 1.5 3H21"/></svg>
      </span>
      INFO&nbsp;CLINIC
    </a>

    <span class="rating-chip">
      <span class="stars">★★★★★</span> <b>5.0</b> · 100+ обследований
    </span>

    <a href="/zayavka" class="btn sm">
      Записаться
      <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </div>
</header>

<style>
  .topbar {
    position: sticky; top: 0; z-index: 50;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(4, 20, 12, 0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .tb-container {
    display: flex; align-items: center; justify-content: space-between; gap: 14px;
    height: 64px;
    padding: 0 clamp(20px, 5vw, 50px);
    max-width: 1600px;
    margin: 0 auto;
  }
  .logo { display: inline-flex; align-items: center; gap: 10px; font-weight: 800; font-size: 15px; letter-spacing: 0.01em; }
  .logo-mark {
    width: 30px; height: 30px; border-radius: 6px;
    display: grid; place-items: center;
    background: var(--vital-soft); border: 1px solid var(--vital-line);
  }
  .logo-mark svg { width: 16px; height: 16px; fill: none; stroke: var(--vital); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  .rating-chip {
    display: none; align-items: center; gap: 8px;
    margin-left: auto;
    font-size: 11px; color: var(--mute);
    border: 1px solid var(--line); border-radius: 6px;
    padding: 6px 12px; background: var(--surface-2);
  }
  .rating-chip .stars { color: var(--gold); letter-spacing: 2px; font-size: 10px; }
  .rating-chip b { color: var(--bone); font-weight: 700; }
  @media (min-width: 1000px) { .rating-chip { display: inline-flex; } }

  .topbar .btn.sm {
    padding: 10px 18px; font-size: 13px; border-radius: 6px;
  }

  @media (max-width: 380px) {
    .logo { font-size: 13px; gap: 8px; }
    .logo-mark { width: 32px; height: 32px; }
    .logo-mark svg { width: 18px; height: 18px; }
    .topbar .btn.sm { padding: 8px 12px; font-size: 13px; gap: 6px; }
    .tb-container { padding: 0 16px; height: 56px; }
  }
</style>
