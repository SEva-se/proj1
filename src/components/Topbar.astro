---
// Шапка. Текст дословно из исходника blk1 .topbar:
// логотип «INFO CLINIC», рейтинг «★★★★★ 5.0 · 100+ обследований», кнопка «Записаться».
// Кнопка ведёт на анкету (требование: CTA → форма).
---
<header class="topbar">
  <div class="container">
    <a href="/" class="logo">
      <span class="logo-mark">
        <svg viewBox="0 0 24 24"><path d="M3 12h4l2-5 3 11 2-7 1.5 3H21"/></svg>
      </span>
      INFO&nbsp;CLINIC
    </a>

    <span class="rating-chip">
      <span class="stars">★★★★★</span> <b>5.0</b> · 100+ обследований
    </span>

    <a href="/zayavka" class="btn sm">
      Записаться
      <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </div>
</header>

<style>
  .topbar {
    position: sticky; top: 0; z-index: 50;
    border-bottom: 1px solid var(--line);
    background: var(--ink);
  }
  .topbar .container {
    display: flex; align-items: center; gap: 18px;
    height: 70px;
  }
  .logo { display: inline-flex; align-items: center; gap: 11px; font-weight: 800; font-size: 16px; letter-spacing: 0.01em; }
  .logo-mark {
    width: 38px; height: 38px; border-radius: 7px;
    display: grid; place-items: center;
    background: var(--vital-soft); border: 1px solid var(--vital-line);
  }
  .logo-mark svg { width: 21px; height: 21px; fill: none; stroke: var(--vital); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  .rating-chip {
    display: none; align-items: center; gap: 8px;
    margin-left: auto;
    font-size: 13px; color: var(--mute);
    border: 1px solid var(--line); border-radius: 6px;
    padding: 9px 14px; background: var(--surface-2);
  }
  .rating-chip .stars { color: var(--gold); letter-spacing: 2px; font-size: 12px; }
  .rating-chip b { color: var(--bone); font-weight: 700; }
  @media (min-width: 1000px) { .rating-chip { display: inline-flex; } }

  .topbar .btn.sm {
    margin-left: auto;
    padding: 10px 18px; font-size: 14px; border-radius: 6px;
  }
  @media (min-width: 1000px) { .topbar .btn.sm { margin-left: 0; } }
</style>
