---
// blk11 · Как проходит обследование проекта — 4 шага.
// Весь текст ДОСЛОВНО из «Сайт новый.html».
import zoomImg from '../../assets/img/img-17-5fb8dcf8.jpg';
import zoomVideo from '../../assets/img/proof/download.mp4';

const steps = [
  { num: '01', tag: 'Шаг 1', h3: 'Записываемся на приём', p: 'После заявки мы связываемся с вами и согласовываем удобное время встречи.' },
  { num: '02', tag: 'Шаг 2', h3: 'Подготавливаемся к обследованию', p: 'Обследование проходит в Zoom и желательно с включённой камерой. Лучше выделить спокойное место, где вас никто не будет отвлекать ближайшие 90 минут.' },
  { num: '03', tag: 'Шаг 3', h3: 'Проводим диагностику', p: 'В течение полутора часов мы разбираем ваш проект: продукт, оффер, упаковку, воронку, трафик и продажи. Ищем не симптомы, а реальные причины, которые сейчас сдерживают рост.' },
  { num: '04', tag: 'Шаг 4', h3: 'Получаете диагноз и план действий', p: 'По итогам встречи вы уходите с пониманием слабых мест проекта, приоритетных точек роста и конкретными шагами, которые стоит внедрить в первую очередь.' },
];
---
<section class="section" id="blk11">
  <div class="container">
    <div class="head rv">
      <div class="rv d1"><span class="badge-pill">🗺️ Дорожная карта</span></div>
      <span class="eyebrow">Как проходит</span>
      <h2 class="rv d2">Как проходит <span class="hl">обследование проекта</span><span class="e">🔍</span></h2>
    </div>

    <div class="feature hover-card rv">
      <div class="bar">
        <span class="d"></span><span class="d"></span><span class="d"></span>
        <span class="l"><span class="rec"></span>Онлайн · Zoom</span>
      </div>
      <video
        class="feature-video"
        src={zoomVideo}
        poster={zoomImg.src}
        autoplay
        muted
        loop
        playsinline
        disablepictureinpicture
        preload="metadata"
      ></video>
    </div>

    <div class="steps">
      {steps.map((s, i) => (
        <div class:list={['step', 'hover-card', 'rv', { d1: i % 2 === 1 }]}>
          <div class="top">
            <span class="num">{s.num}</span>
            <span class="tag">{s.tag}</span>
          </div>
          <h3>{s.h3}</h3>
          <p>{s.p}</p>
        </div>
      ))}
    </div>

    <div class="cta-wrap rv">
      <a href="/zayavka" class="btn pulse">
        Записаться на приём
        <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .head { margin-bottom: clamp(32px, 5vw, 48px); display: flex; flex-direction: column; align-items: center; text-align: center; }
  #blk11 h2 { font-size: clamp(25px, 3.8vw, 44px); line-height: 1.14; margin-top: 18px; max-width: 24ch; text-align: center; }

  /* ---- feature monitor ---- */
  .feature {
    border: 1px solid var(--line); border-radius: 8px; overflow: hidden;
    background: var(--surface); max-width: 640px;
    margin: 0 auto clamp(40px, 6vw, 56px);
  }
  .bar {
    display: flex; align-items: center; gap: 6px;
    padding: 10px 14px; border-bottom: 1px solid var(--line);
    background: var(--surface-2);
  }
  .bar .d { width: 8px; height: 8px; border-radius: 50%; }
  .bar .d:nth-child(1) { background: var(--alert); }
  .bar .d:nth-child(2) { background: var(--gold); }
  .bar .d:nth-child(3) { background: var(--vital); }
  .bar .l {
    margin-left: auto;
    display: flex; align-items: center; gap: 8px;
    font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--mute-2);
  }
  .rec {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--alert);
    animation: blink 1.8s infinite;
  }
  .feature :global(img) { width: 100%; display: block; height: auto; }
  .feature-video { width: 100%; display: block; height: auto; background: #000; pointer-events: none; }

  /* ---- steps ---- */
  .steps {
    display: grid; grid-template-columns: 1fr; gap: 18px;
  }
  @media (min-width: 760px) { .steps { grid-template-columns: 1fr 1fr; } }

  .step {
    padding: clamp(22px, 3vw, 28px);
    border: 1px solid var(--line); border-radius: 8px;
    background: var(--surface-2);
    transition: border-color 0.35s var(--ease), transform 0.35s var(--ease);
  }
  .step:hover { border-color: var(--vital-line); transform: translateY(-3px); }

  .top { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .num {
    font-family: var(--font-mono); font-size: clamp(28px, 4vw, 36px);
    font-weight: 800; color: var(--vital); line-height: 1;
  }
  .tag {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--mute-2);
    border: 1px solid var(--line); border-radius: 4px; padding: 4px 10px;
  }
  .step h3 { font-size: clamp(17px, 2.2vw, 21px); line-height: 1.25; margin-bottom: 8px; }
  .step p { font-size: 16px; line-height: 1.6; color: var(--bone); font-weight: 500; }

  .cta-wrap { text-align: center; margin-top: clamp(36px, 5vw, 52px); }

  @media (max-width: 560px) {
    .cta-wrap .btn { width: 100%; }
    .step { padding: 18px 16px; }
    .num { font-size: 24px; }
    .step h3 { font-size: 18px; }
  }
</style>
