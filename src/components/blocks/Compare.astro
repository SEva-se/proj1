---
// blk1 · b2 — «Почему это не обычная бесплатная консультация».
// Весь текст ДОСЛОВНО из «Сайт новый.html». Фото Zoom-сессий — реальные (img-01..04),
// отдаются через astro:assets (WebP/AVIF, lazy). CTA → анкета.
import { Image } from 'astro:assets';
import z1 from '../../assets/img/img-01-66bb6bb6.jpg';
import z2 from '../../assets/img/img-02-3804f3d0.jpg';
import z3 from '../../assets/img/img-03-65987782.jpg';
import z4 from '../../assets/img/img-04-34dae628.jpg';

const rows = [
  ['от 20 до 30 минут разговора', 'от 90 до 120 минут глубокой диагностики'],
  ['Поверхностный разбор запроса', 'Анализ проекта по 10 зонам'],
  ['Общие рекомендации', 'Решения под вашу ситуацию'],
  ['Обсуждение симптомов', 'Поиск первопричины проблемы'],
  ['Взгляд на отдельный участок', 'Разбор всего проекта целиком'],
  ['Базовые советы', 'Понятный план действий'],
  ['Опора на мнение специалиста', 'Опора на данные и факты'],
  ['Уходите с идеями', 'Уходите с диагнозом и планом'],
];
const shots = [z1, z2, z3, z4];
---
<section class="section" id="b2">
  <div class="container">
    <h2 class="rv d2">Почему это не обычная <span class="hl text-hl-bg">бесплатная консультация</span><span class="e">⚖️</span></h2>
    <p class="lead rv">Большинство бесплатных консультаций заканчиваются несколькими советами и общими рекомендациями. Обследование проекта устроено иначе: от 90 до 120 минут мы разбираем проект по 10 ключевым зонам, чтобы найти не симптом, а реальную причину, которая сдерживает ваш рост.</p>
  </div>

  <div class="cmp-track" id="cmpTrack">
    <div class="cmp-sticky" id="cmpSticky">
      <div class="container">
        <div class="b2grid">
      <!-- таблица сравнения -->
      <div class="cmp rv d1">
        <div class="cmp-head">
          <div class="l">Обычная бесплатная консультация</div>
          <div class="r">Обследование проекта</div>
        </div>
        {rows.map(([l, r]) => (
          <div class="cmp-row cmp-anim-row">
            <div class="l"><span class="mk"></span>{l}</div>
            <div class="r">
              <span class="mk"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>{r}
            </div>
          </div>
        ))}
      </div>

      <!-- фотодоска реальных сессий -->
      <div class="b2board rv d2">
        {shots.map((src) => (
          <div class="b2pcard">
            <span class="z"><span class="d"></span>Zoom</span>
            <Image src={src} alt="Сессия обследования в Zoom" loading="lazy" />
          </div>
        ))}
        <div class="b2cap">Реальные сессии обследования</div>
      </div>
    </div>
      </div>
    </div>
  </div>
  <div class="container">
    <div class="closer rv">
      <p>Цель обследования не дать ещё несколько советов. Цель обследования показать, где именно ваш проект теряет деньги, клиентов и возможности.</p>
      <a href="/zayavka" class="btn lg">
        Посмотреть, что покажет обследование моего проекта
        <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  #b2 h2 { font-size: clamp(26px, 4vw, 44px); line-height: 1.12; margin: 18px 0 16px; max-width: 25ch; }
  #b2 .lead { color: var(--mute); font-size: clamp(15px, 1.8vw, 19px); line-height: 1.6; max-width: 56ch; margin-bottom: clamp(34px, 5vw, 52px); font-weight: 500; }

  .b2grid { display: grid; grid-template-columns: 1fr; gap: clamp(28px, 4vw, 44px); align-items: start; }
  @media (min-width: 900px) { .b2grid { grid-template-columns: 1.04fr 0.96fr; } }

  /* ---- Sticky Scroll ---- */
  @media (min-width: 900px) {
    .cmp-track { height: 180vh; position: relative; padding: 0; }
    .cmp-sticky { position: sticky; top: 70px; height: calc(100vh - 70px); display: flex; align-items: center; padding: 0; overflow: hidden; }
    .cmp-sticky .container { width: 100%; display: flex; flex-direction: column; justify-content: center; }

    .cmp-head > div { padding: 12px 14px; }
    .cmp-row > div { padding: 11px 14px; }
  }

  @media (min-width: 900px) and (max-height: 600px) {
    .cmp-track { height: auto; }
    .cmp-sticky { position: relative; height: auto; padding: 40px 0; overflow: visible; }
  }

  /* ---- таблица сравнения (строгие границы) ---- */
  .cmp { border: 1px solid var(--line); border-radius: 8px; overflow: hidden; background: var(--card); }
  .cmp-head, .cmp-row { display: grid; grid-template-columns: 1fr 1fr; position: relative; }
  .cmp-head::after, .cmp-row::after { content: ''; position: absolute; top: 0; bottom: 0; left: 50%; width: 1px; background: var(--line); z-index: 1; }
  
  .cmp-head > div { padding: 16px 18px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; }
  .cmp-head .l { color: var(--mute); }
  .cmp-head .r { background: var(--vital-soft); color: var(--vital); display: flex; align-items: center; gap: 9px; position: relative; z-index: 2; }
  .cmp-head .r::before { content: ""; width: 7px; height: 7px; border-radius: 50%; background: var(--vital); box-shadow: 0 0 10px var(--vital); flex: none; }
  .cmp-row { border-top: 1px solid var(--line); }
  .cmp-row > div { padding: 14px 18px; display: flex; align-items: flex-start; gap: 11px; font-size: clamp(13px, 1.6vw, 15px); line-height: 1.4; position: relative; z-index: 2; }
  
  .cmp-row .l { 
    color: var(--mute); font-weight: 500; 
    transition: opacity 0.5s ease, transform 0.5s ease; 
    transform-origin: left center;
  }
  .cmp-row .r { 
    color: var(--bone); font-weight: 600; 
    background: transparent; 
    transition: background-color 0.5s ease, opacity 0.5s ease, transform 0.5s ease;
    opacity: 0.35;
    transform-origin: right center;
  }
  .cmp .mk { flex: none; }
  .cmp .l .mk { width: 10px; height: 2px; background: var(--mute-2); margin-top: 9px; }
  .cmp .r .mk { width: 15px; height: 15px; margin-top: 2px; }
  .cmp .r .mk svg { width: 15px; height: 15px; fill: none; stroke: var(--mute-2); stroke-width: 2.6; transition: stroke 0.5s ease; }

  /* Animation states */
  .cmp-anim-row.is-active .l { opacity: 0.25; transform: scale(0.92); }
  .cmp-anim-row.is-active .r { background: var(--vital-soft); opacity: 1; }
  .cmp-anim-row.is-active .r .mk svg { stroke: var(--vital); }

  /* ---- фотодоска (стопка повёрнутых карточек) ---- */
  .b2board { display: flex; flex-direction: column; position: relative; padding: 4px 2px; }
  .b2pcard {
    position: relative; width: 90%; border-radius: 8px; overflow: hidden;
    border: 1px solid rgba(236, 234, 228, 0.16);
    box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.35);
    background: var(--surface-2);
    transition: transform 0.45s var(--ease);
  }
  .b2pcard img { width: 100%; display: block; height: auto; }
  .b2pcard .z {
    position: absolute; top: 9px; left: 9px;
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-mono); font-size: 8px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--bone); background: rgba(8, 9, 11, 0.62); border: 1px solid var(--line);
    border-radius: 4px; padding: 4px 9px;
  }
  .b2pcard .z .d { width: 5px; height: 5px; border-radius: 50%; background: var(--alert); }
  .b2pcard:not(:first-child) { margin-top: -7.5%; }
  .b2pcard:nth-child(1) { transform: rotate(-3deg); align-self: flex-start; z-index: 1; }
  .b2pcard:nth-child(2) { transform: rotate(2.4deg); margin-left: auto; z-index: 2; }
  .b2pcard:nth-child(3) { transform: rotate(-2deg); align-self: flex-start; z-index: 3; }
  .b2pcard:nth-child(4) { transform: rotate(3deg); margin-left: auto; z-index: 4; }
  .b2pcard:hover { transform: rotate(0) translateY(-4px); z-index: 20; }
  .b2cap { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-2); text-align: center; margin-top: 20px; }

  /* ---- closer ---- */
  .closer {
    max-width: 660px; margin: clamp(44px, 6vw, 72px) auto 0;
    padding-top: clamp(36px, 5vw, 52px); border-top: 1px solid var(--line);
    text-align: center; display: flex; flex-direction: column; align-items: center; gap: clamp(22px, 3vw, 30px);
  }
  .closer p { font-size: clamp(17px, 2.2vw, 21px); line-height: 1.5; color: var(--bone); font-weight: 500; }
  .closer .btn.lg { border-radius: 6px; }

  @media (max-width: 560px) {
    .closer .btn.lg { width: 100%; }
    .cmp-head > div { padding: 13px 13px; font-size: 9.5px; letter-spacing: 0.08em; }
    .cmp-row > div { padding: 12px 13px; gap: 9px; }
  }
</style>

<script>
  function initCompareAnim() {
    const track = document.getElementById('cmpTrack');
    const rows = document.querySelectorAll('.cmp-anim-row');
    if (!track || !rows.length) return;

    let maxProgress = 0;

    function onScroll() {
      // Check if desktop (sticky active)
      if (window.innerWidth < 900 || window.innerHeight < 600) {
        // Fallback to simple intersection observer logic for mobile/short viewports
        rows.forEach(row => {
          const rect = row.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.8 && rect.bottom > 0) {
            row.classList.add('is-active');
          }
        });
        return;
      }

      const rect = track.getBoundingClientRect();
      const trackTop = rect.top;
      const trackHeight = rect.height;
      const windowHeight = window.innerHeight;
      
      const stickyTopOffset = 70;
      const maxScroll = trackHeight - windowHeight + stickyTopOffset;
      let progress = 0;
      
      if (maxScroll > 0) {
        progress = (stickyTopOffset - trackTop) / maxScroll;
      }
      progress = Math.max(0, Math.min(1, progress));
      
      if (progress > maxProgress) {
        maxProgress = progress;
      }
      
      const totalRows = rows.length;
      rows.forEach((row, index) => {
        // distribute thresholds evenly across progress
        const threshold = index / (totalRows + 1); // e.g. 0, 0.11, 0.22...
        if (maxProgress > threshold) {
          row.classList.add('is-active');
        }
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    onScroll();
  }
  
  document.addEventListener('DOMContentLoaded', initCompareAnim);
  document.addEventListener('astro:page-load', initCompareAnim);
</script>
