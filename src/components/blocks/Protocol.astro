---
// blk5 · Методология диагностики — протокол обследования.
// Весь текст ДОСЛОВНО из «Сайт новый.html». 4 шага + аудит + скриншоты.
import { Image } from 'astro:assets';
import img05 from '../../assets/img/img-05-8cc9af80.jpg';
import img07 from '../../assets/img/img-07-f4481027.jpg';
import img09 from '../../assets/img/img-09-b01b3f95.jpg';
import img11 from '../../assets/img/img-11-a8dde50b.jpg';
import img13 from '../../assets/img/img-13-37e7a116.jpg';
import img15 from '../../assets/img/img-15-fd1100a2.jpg';

const steps = [
  {
    num: '01', tag: '01 · Обследование',
    h3: 'Вскрываем проект по 10 зонам',
    p: 'Прогоняем проект через маркетинговый сканер по 10 зонам: позиционирование, аудитория, оффер, продукт, контент, трафик, воронка, продажи, запуски, аналитика. Каждой зоне ставим оценку.',
    shots: [
      { src: img05, label: 'ЗОНЫ С 1 ПО 5', alt: 'Зоны 1-5' },
      { src: img07, label: 'ЗОНЫ С 6 ПО 10', alt: 'Зоны 6-10' },
    ],
    two: true, rev: false,
  },
  {
    num: '02', tag: '02 · Диагностика',
    h3: 'Видим, где проект проседает',
    p: 'Сканер сводит все оценки в один снимок проекта. Виден общий балл и зоны, которые тянут вас вниз. Ничего на глаз, только показатели.',
    shots: [
      { src: img09, label: 'ДИАГНОСТИКА СИСТЕМЫ', alt: 'Диагностика системы и колесо баланса' },
    ],
    two: false, rev: true,
  },
  {
    num: '03', tag: '03 · Диагноз',
    h3: 'Вскрываем 3 самые болевые зоны',
    p: 'Из всех зон сканер вытаскивает три самых слабых, очаги, где прямо сейчас утекают деньги. С них и начинаем.',
    shots: [
      { src: img11, label: 'ТОЧКИ ПОТЕРИ ПРИБЫЛИ', alt: 'Топ-3 слабые зоны' },
    ],
    two: false, rev: false,
  },
  {
    num: '04', tag: '04 · План лечения',
    h3: 'Персональный план действий',
    p: 'Под каждую больную зону свое конкретное лечение: что делать, какими инструментами и в какие сроки. Не советы «вообще», а маршрут под ваш проект.',
    shots: [
      { src: img13, label: 'ПЛАН ДЕЙСТВИЙ', alt: 'План действий' },
    ],
    two: false, rev: true,
  },
];
---
<section class="section" id="blk5">
  <div class="container">

    <span class="eyebrow rv d1">Методология диагностики</span>
    <div class="title-wrap rv d2">
      <h2>По какой технологии мы <span class="hl">обследуем</span> ваш проект</h2>
      <div class="title-emoji">🔬</div>
    </div>
    <p class="lead rv d3">Каждый проект проходит через маркетинговый сканер. Ниже реальные экраны с диагностической сессии.</p>

    <div class="protocol-timeline">
      {steps.map((s) => (
        <div class="pt-step rv">
          <div class="pt-marker"></div>
          <div class="pt-card hover-card">
            <div class="pt-card-header">
              <div class="pt-tag">{s.tag}</div>
              <h3>{s.h3}</h3>
            </div>
            <div class="pt-card-body">
              <div class="pt-info">
                <div class="pt-snum">{s.num}</div>
                <p>{s.p}</p>
              </div>
              
              <div class={`pt-media-grid cols-${s.shots.length}`}>
                {s.shots.map((shot) => (
                  <div class="pt-media">
                    <div class="mon-bar">
                      <span class="d"></span><span class="d"></span><span class="d"></span>
                      <span class="l">{shot.label}</span>
                    </div>
                    <div class="pt-shotbox">
                      <Image src={shot.src} alt={shot.alt} loading="lazy" />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}

      <!-- audit document -->
      <div class="pt-step rv">
        <div class="pt-marker final"></div>
        <div class="pt-card audit-card hover-card">
          <div class="pt-card-header">
            <div class="pt-tag">05 · Что вы получаете</div>
            <h3>Итоговый аудит-документ 📋</h3>
          </div>
          <div class="pt-card-body">
            <div class="pt-info">
              <div class="pt-snum">05</div>
              <p class="sub">После обследования у вас остаётся большой PDF: глубокая аналитика текущей ситуации, разбор по ключевым метрикам и стратегия развития с учётом новых инструментов и анализа рынка.</p>
            </div>
            <div class="pt-media-grid cols-1">
              <div class="pt-media doc-media">
                <div class="mon-bar">
                  <span class="d"></span><span class="d"></span><span class="d"></span>
                  <span class="l">ИТОГОВЫЙ АУДИТ · PDF</span>
                </div>
                <div class="pt-shotbox">
                  <Image src={img15} alt="Готовый аудит проекта" loading="lazy" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="cta-wrap rv">
      <a href="/zayavka" class="btn pulse">
        Пройти обследование и получить аудит
        <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  #blk5 h2 { font-size: clamp(25px, 3.8vw, 44px); line-height: 1.14; margin: 18px 0 14px; max-width: 20ch; }
  .lead { color: var(--bone); font-size: clamp(17px, 2vw, 21px); line-height: 1.6; max-width: 60ch; margin-bottom: clamp(40px, 6vw, 64px); font-weight: 500; }

  /* ---- protocol timeline ---- */
  .protocol-timeline {
    display: flex; flex-direction: column; gap: 32px; position: relative;
    margin-top: 40px;
  }
  @media (min-width: 900px) {
    .protocol-timeline::before {
      content: ''; position: absolute; top: 32px; bottom: 32px; left: 19px;
      width: 2px; background: linear-gradient(180deg, var(--vital), transparent);
      opacity: 0.2;
    }
  }

  .pt-step {
    position: relative; 
  }
  @media (min-width: 900px) {
    .pt-step { padding-left: 60px; }
  }

  .pt-marker {
    display: none;
  }
  @media (min-width: 900px) {
    .pt-marker {
      display: block; position: absolute; left: 13px; top: 40px; width: 14px; height: 14px;
      background: var(--surface-2); border: 2px solid var(--vital); border-radius: 50%;
      box-shadow: 0 0 10px var(--vital); z-index: 2;
    }
    .pt-marker.final {
      background: var(--vital); box-shadow: 0 0 20px var(--vital); width: 18px; height: 18px; left: 11px;
    }
  }

  /* ---- bento cards ---- */
  .pt-card {
    display: flex; flex-direction: column;
    background: var(--surface-2); border: 1px solid rgba(236, 234, 228, 0.08);
    border-radius: 16px; overflow: hidden;
    transition: border-color 0.4s ease, transform 0.4s ease;
  }
  .pt-card:hover { border-color: rgba(236, 234, 228, 0.15); transform: translateY(-2px); }

  .pt-card-header {
    background: var(--vital-soft);
    padding: 24px;
    border-bottom: 1px solid var(--vital-line);
  }
  
  .pt-card-body {
    display: grid; grid-template-columns: 1fr; gap: 24px;
    padding: 24px;
  }

  @media (min-width: 900px) {
    .pt-card-header { padding: 32px 36px; }
    .pt-card-body { padding: 36px; grid-template-columns: 1fr 1.1fr; gap: 40px; align-items: stretch; }
    .audit-card .pt-card-body { grid-template-columns: 1.1fr 0.9fr; }
  }

  /* audit card text block */
  .audit-card .sub { font-size: 17px; font-weight: 500; text-wrap: pretty; }

  /* Info Side */
  .pt-info { position: relative; display: flex; flex-direction: column; justify-content: center; height: 100%; z-index: 1; padding: 20px 0; }
  .pt-snum { 
    position: absolute; top: -10px; left: -10px; 
    font-family: var(--font-mono); font-size: 160px; font-weight: 900; line-height: 0.8; 
    color: var(--vital); opacity: 0.03; z-index: -1; pointer-events: none; user-select: none; 
  }
  .pt-tag { font-family: var(--font-mono); font-size: 16px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--vital); margin-bottom: 12px; }
  .pt-card-header h3 { font-size: clamp(24px, 3vw, 32px); font-weight: 800; line-height: 1.2; color: var(--bone); margin: 0; }
  .pt-info p { font-size: clamp(20px, 2.2vw, 28px); color: var(--bone); line-height: 1.5; font-weight: 500; text-wrap: pretty; max-width: 48ch; }

  /* Media Constraints */
  .pt-media-grid { display: grid; gap: 16px; }
  @media (min-width: 700px) {
    .pt-media-grid.cols-2 { grid-template-columns: 1fr 1fr; }
  }

  .pt-media {
    position: relative;
    background: var(--surface); border: 1px solid var(--line); border-radius: 8px;
    overflow: hidden; max-height: 340px; display: flex; flex-direction: column;
  }
  @media (min-width: 900px) {
    .pt-media { max-height: 440px; }
  }
  .doc-media { max-height: 500px; }
  @media (min-width: 900px) {
    .doc-media { max-height: 600px; }
  }

  .mon-bar {
    display: flex; align-items: center; gap: 6px; padding: 10px 14px;
    border-bottom: 1px solid var(--line); background: var(--surface-2); flex: none;
  }
  .mon-bar .d { width: 8px; height: 8px; border-radius: 50%; }
  .mon-bar .d:nth-child(1) { background: var(--alert); }
  .mon-bar .d:nth-child(2) { background: var(--gold); }
  .mon-bar .d:nth-child(3) { background: var(--vital); }
  .mon-bar .l { margin-left: auto; font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-2); }

  .pt-shotbox {
    position: relative; overflow: hidden; flex: 1;
  }
  .pt-shotbox img { width: 100%; display: block; height: auto; object-fit: cover; object-position: top; }
  
  /* Fade out long images smoothly */
  .pt-shotbox::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 60px;
    background: linear-gradient(0deg, var(--surface) 0%, transparent 100%);
    pointer-events: none;
  }

  /* ---- cta ---- */
  .cta-wrap { text-align: center; margin-top: clamp(36px, 5vw, 52px); }

  @media (max-width: 560px) {
    .cta-wrap .btn { width: 100%; }
    .pt-card-header { padding: 16px; }
    .pt-card-body { padding: 16px; gap: 20px; }
    .pt-card-header h3 { font-size: 22px; }
  }
</style>
