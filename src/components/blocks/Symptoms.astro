---
// blk1 · b3 — «Симптомы проекта» (карты пациента). Текст ДОСЛОВНО из «Сайт новый.html».
// 8 карточек: Симптом → Что обычно думают → Что часто оказывается на практике.
const cards = [
  { sym: 'Заявки есть, а продаж меньше, чем раньше.', think: 'Нужно больше трафика.', dx: 'Проблема в оффере или механике продажи' },
  { sym: 'Контента стало больше, а заявок больше не стало.', think: 'Нужно чаще публиковаться.', dx: 'Даете нерелеватный контент, отсутствует дожимная воронка продаж' },
  { sym: 'Каждый запуск приходится буквально вытаскивать вручную.', think: 'Рынок умер.', dx: 'Нет предсказуемой системы продаж, ведете проект хаотичными действиями' },
  { sym: 'Продажи нестабильны. Каждый месяц разные результаты.', think: 'Нужно больше клиентов и больше трафика.', dx: 'В проекте нет предсказуемой воронки продаж и отсутстует аналитика . Всё держится на случайных заявках и сарафане.' },
  { sym: 'Просмотры есть, заявок и продаж нет или слабые', think: 'Проблема в рекламе или алгоритмах.', dx: 'Упаковка не доносит ценность продукта. Люди смотрят, но не понимают, почему им это нужно.' },
  { sym: 'Деньги в проект вкладываются. Рост почти не ощущается.', think: 'Нужно найти нового подрядчика.', dx: 'Решения принимаются без аналитики. Никто не понимает, что именно приносит результат.' },
  { sym: 'Кажется, что проект упёрся в потолок.', think: 'Рынок перегрет. Ниша больше не работает.', dx: 'Старые инструменты просто перестали работать. Проекту нужна новая упаковка и бизнес модель' },
  { sym: 'Всё держится на владельце проекта.', think: 'Так и должно быть.', dx: 'Нет системы. Если собственник перестанет тянуть процессы вручную проект остановится.' },
];

// разные линейные мед-иконки для каждой карточки (декор, не текст)
const icons = [
  'M3 12h4l2-5 3 11 2-7 1.5 3H21',
  'M3 5h18l-7 8v6l-4-2v-4z',
  'M4 7l5 5 4-4 7 7M16 15h4v4',
  'M12 3a9 9 0 100 18 9 9 0 000-18zM12 8v4l3 2',
  'M21 8l-9-5-9 5 9 5 9-5zM3 8v8l9 5 9-5V8',
  'M5 21V10M12 21V4M19 21v-7',
  'M4 12a8 8 0 0113-5l3 3M3 7v3h3M20 12a8 8 0 01-13 5l-3-3M21 17v-3h-3',
  'M12 12a4 4 0 100-8 4 4 0 000 8zM5 21a7 7 0 0114 0',
];

const pad2 = (n: number) => String(n + 1).padStart(2, '0');
---
<section class="section" id="b3">
  <div class="sym-track" id="symTrack">
    <div class="sym-sticky" id="symSticky">
      <div class="container">
        
        <div class="sym-layout">
          <!-- Левая колонка: текст -->
          <div class="sym-left rv d1">
            <div class="rv d1"><span class="badge-pill">🩺 Диагностика проблем</span></div>
            <span class="eyebrow">Симптомы проекта</span>
            <h2 class="rv d2">Узнаёте свой проект? Это самые частые симптомы, которые мы встречаем на <span class="hl text-hl-bg">обследованиях</span><span class="e">📊</span></h2>
          </div>

          <!-- Правая колонка: стопка карточек -->
          <div class="sym-right">
            <div class="sym-stack">
              {cards.map((c, n) => (
                <article class="pc sym-card rv" data-idx={n} style={`z-index: ${cards.length - n}`}>
                  <div class="pc-head">
                    <span class="badge">Карточка пациента · №{pad2(n)}</span>
                    <span class="status"><span class="d"></span>Требует диагностики</span>
                  </div>
                  <div class="pc-body">
                    <div class="sympt">
                      <span class="av">
                        <svg viewBox="0 0 24 24"><path d={icons[n]} /></svg>
                      </span>
                      <div class="fld sym">
                        <div class="lbl">Симптом 🤒</div>
                        <p>{c.sym}</p>
                      </div>
                    </div>
                    <div class="cdiv"></div>
                    <div class="fld think">
                      <div class="lbl">Что обычно думают 💭</div>
                      <p>{c.think}</p>
                    </div>
                    <div class="dx">
                      <div class="lbl">
                        <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                        Что часто оказывается на практике 💡
                      </div>
                      <p>{c.dx}</p>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="container">
    <div class="closer rv">
      <p>Если вы узнали свой проект хотя бы в двух симптомах, обследование может показать причину намного быстрее, чем очередной месяц экспериментов ⏳.</p>
      <a href="/zayavka" class="btn lg pulse">
        Пройти бесплатное обследование проекта
        <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  #b3 { position: relative; }
  #b3 h2 { font-size: clamp(25px, 3.8vw, 44px); line-height: 1.14; margin: 18px 0 clamp(36px, 5vw, 56px); max-width: 24ch; }

  /* ---- Layout ---- */
  .sym-track { height: auto; position: relative; }
  .sym-sticky { position: relative; padding: 40px 0; }
  .sym-layout { display: flex; flex-direction: column; gap: 40px; }
  
  @media (min-width: 900px) {
    .sym-track { height: 400vh; padding: 0; }
    .sym-sticky { position: sticky; top: 70px; height: calc(100vh - 70px); display: flex; align-items: center; padding: 0; overflow: hidden; }
    .sym-layout { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 60px; align-items: center; width: 100%; }
    #b3 h2 { margin-bottom: 0; }
  }

  /* ---- Card Stack ---- */
  .sym-stack { display: grid; width: 100%; max-width: 480px; margin: 0 auto; perspective: 1200px; }
  
  .pc {
    display: flex; flex-direction: column;
    border: 1px solid rgba(236, 234, 228, 0.16); border-radius: 12px; overflow: hidden;
    background: var(--surface-2);
    box-shadow: 0 16px 40px rgba(0,0,0,0.4);
    transition: border-color 0.35s var(--ease);
  }
  .pc:hover { border-color: var(--vital-line); }

  .sym-card {
    grid-area: 1 / 1; align-self: stretch;
    width: 100%;
    transform-origin: center 80%;
    will-change: transform, opacity;
  }

  @media (max-width: 899px) {
    .sym-stack { display: flex; flex-direction: column; gap: 16px; perspective: none; }
    .sym-card { grid-area: auto; transform: none !important; opacity: 1 !important; z-index: auto !important; }
  }

  .pc-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 14px 18px; border-bottom: 1px solid var(--line); }
  .badge { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; color: var(--gold); border: 1px solid var(--gold-line); border-radius: 4px; padding: 5px 10px; text-transform: uppercase; }
  .status { display: inline-flex; align-items: center; gap: 7px; font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.1em; color: var(--mute); text-transform: uppercase; white-space: nowrap; }
  .status .d { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); box-shadow: 0 0 8px var(--gold-line); }

  .pc-body { padding: 20px 18px; display: flex; flex-direction: column; gap: 15px; flex: 1; }
  .sympt { display: flex; align-items: flex-start; gap: 13px; }
  .av {
    width: 44px; height: 44px; flex: none; border-radius: 8px;
    display: grid; place-items: center;
    background: var(--vital-soft); border: 1px solid var(--vital-line);
  }
  .av svg { width: 22px; height: 22px; fill: none; stroke: var(--vital); stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }

  .fld .lbl { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--mute-2); margin-bottom: 6px; }
  .fld.sym .lbl { color: var(--mute); }
  .fld.sym p { font-size: clamp(15px, 1.9vw, 17px); font-weight: 600; line-height: 1.32; color: var(--bone); }
  .fld.think p { font-size: 14px; font-weight: 500; line-height: 1.4; color: var(--mute); }
  .cdiv { height: 1px; background: var(--line); }

  .dx {
    margin: auto -18px -20px; padding: 16px 18px 18px;
    background: var(--vital-soft); border-top: 1px solid var(--vital-line);
    position: relative;
  }
  .dx::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--vital); }
  .dx .lbl { display: flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--vital); margin-bottom: 7px; }
  .dx .lbl svg { width: 13px; height: 13px; fill: none; stroke: var(--vital); stroke-width: 2.6; }
  .dx p { font-size: 15px; font-weight: 600; line-height: 1.45; color: var(--bone); }

  .closer {
    max-width: 660px; margin: clamp(44px, 6vw, 72px) auto 0;
    padding-top: clamp(36px, 5vw, 52px); border-top: 1px solid var(--line);
    text-align: center; display: flex; flex-direction: column; align-items: center; gap: clamp(22px, 3vw, 30px);
  }
  .closer p { font-size: clamp(17px, 2.2vw, 21px); line-height: 1.5; color: var(--bone); font-weight: 500; }
  .closer .btn.lg { border-radius: 6px; }

  @media (max-width: 560px) {
    .closer .btn.lg { width: 100%; }
    .dx { margin: 4px -18px -20px; }
  }
</style>

<script>
  function initSymAnim() {
    const track = document.getElementById('symTrack');
    const cards = document.querySelectorAll('.sym-card');
    if (!track || !cards.length) return;

    function onScroll() {
      if (window.innerWidth < 900) {
        cards.forEach(c => {
          c.style.transform = '';
          c.style.opacity = '';
          c.style.pointerEvents = '';
        });
        return;
      }

      const rect = track.getBoundingClientRect();
      const trackTop = rect.top;
      const trackHeight = rect.height;
      const windowHeight = window.innerHeight;
      
      const stickyTopOffset = 70;
      const maxScroll = trackHeight - windowHeight + stickyTopOffset;
      let progress = 0;
      
      if (maxScroll > 0) {
        progress = (stickyTopOffset - trackTop) / maxScroll;
      }
      progress = Math.max(0, Math.min(1, progress));
      
      // 8 cards -> 7 swipes. t goes from 0 to 7.
      const t = progress * (cards.length - 1);
      const currentIndex = Math.floor(t);
      const p = t - currentIndex; // local progress 0 to 1

      cards.forEach((card, idx) => {
        if (idx < currentIndex) {
          // Already swiped away
          const swipeDir = (idx % 2 === 0) ? -1 : 1;
          card.style.transform = `translateX(${swipeDir * 150}%) rotate(${swipeDir * 30}deg)`;
          card.style.opacity = '0';
          card.style.pointerEvents = 'none';
        } else if (idx === currentIndex) {
          // Currently swiping
          const swipeDir = (idx % 2 === 0) ? -1 : 1;
          const x = p * 150 * swipeDir;
          const r = p * 30 * swipeDir;
          const opacity = 1 - Math.pow(p, 3); // fade out late
          card.style.transform = `translateX(${x}%) rotate(${r}deg)`;
          card.style.opacity = opacity.toString();
          card.style.pointerEvents = p > 0.5 ? 'none' : 'auto';
        } else {
          // Waiting in the stack
          const d = idx - currentIndex - p;
          const scale = Math.max(0, 1 - 0.05 * d);
          const y = Math.max(0, d * 18);
          const opacity = d > 3 ? 0 : 1; // only show top 3-4 cards
          card.style.transform = `translateY(${y}px) scale(${scale})`;
          card.style.opacity = opacity.toString();
          card.style.pointerEvents = 'none';
        }
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    onScroll();
  }

  document.addEventListener('DOMContentLoaded', initSymAnim);
  document.addEventListener('astro:page-load', initSymAnim);
</script>
