<style>
  .hero { 
    position: relative; overflow: hidden; 
    padding: 80px 0 100px 0; 
    display: flex; align-items: flex-start;
    justify-content: center;
  }
  
  .hero-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
  .glow { position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.3; }
  .g1 { top: -10%; left: -5%; width: 500px; height: 500px; background: var(--vital); }
  .g2 { bottom: -10%; right: -5%; width: 600px; height: 600px; background: rgba(230, 185, 128, 0.4); opacity: 0.1; }
  .particles { position: absolute; inset: 0; pointer-events: none; z-index: 0; opacity: 0.5; }
  .dot { 
    position: absolute; 
    border-radius: 50%; 
    background: radial-gradient(circle at center, rgba(63, 221, 154, 0.8) 0%, transparent 70%);
    opacity: 0.15;
    will-change: transform, opacity;
  }
  .dot-1 { width: 12px; height: 12px; top: 20%; left: 10%; animation: float 14s ease-in-out infinite, twinkle 4s ease-in-out infinite; }
  .dot-2 { width: 18px; height: 18px; top: 70%; left: 15%; animation: float 18s ease-in-out infinite reverse, twinkle 5s ease-in-out infinite 1s; }
  .dot-3 { width: 8px; height: 8px; top: 25%; left: 85%; animation: float 12s ease-in-out infinite 2s, twinkle 3s ease-in-out infinite 2s; }
  .dot-4 { width: 15px; height: 15px; top: 80%; left: 80%; animation: float 20s ease-in-out infinite 1s, twinkle 6s ease-in-out infinite 3s; }
  .dot-5 { width: 10px; height: 10px; top: 10%; left: 50%; animation: float 15s ease-in-out infinite reverse 1s, twinkle 4.5s ease-in-out infinite 1.5s; }

  .star {
    position: absolute;
    width: 2px; height: 2px;
    background: var(--vital);
    border-radius: 50%;
    will-change: transform, opacity;
    opacity: 0.1;
  }
  .star::before {
    content: '';
    position: absolute;
    top: 50%; left: 0;
    transform: translateY(-50%);
    width: 60px; height: 1px;
    background: linear-gradient(90deg, var(--vital), transparent);
  }
  .star-1 { top: -10%; left: 30%; animation: shooting-star 6s linear infinite; }
  .star-2 { top: 20%; left: -10%; animation: shooting-star 8s linear infinite 3s; }
  .star-3 { top: -20%; left: 60%; animation: shooting-star 7s linear infinite 5s; }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.3; }
    50% { transform: translate(20px, -30px) scale(1.2); opacity: 0.6; }
  }
  @keyframes shooting-star {
    0% { transform: translate(0, 0) rotate(35deg); opacity: 0; }
    5% { opacity: 1; }
    15% { transform: translate(600px, 420px) rotate(35deg); opacity: 0; }
    100% { transform: translate(600px, 420px) rotate(35deg); opacity: 0; }
  }
  @keyframes spin-float {
    0% { transform: translate(0, 0) rotate(0deg); opacity: 0.2; }
    50% { transform: translate(-30px, 20px) rotate(180deg); opacity: 0.5; }
    100% { transform: translate(0, 0) rotate(360deg); opacity: 0.2; }
  }

  .hero-layout {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; gap: 40px;
    max-width: 760px; margin-inline: auto; text-align: center;
